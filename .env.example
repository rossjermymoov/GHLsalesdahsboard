# GHL API Credentials (required)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=your-location-id-here

# Admin secret for managing invite codes
# If not set, a random one is generated and printed to the console on startup
ADMIN_SECRET=pick-a-strong-secret-here

# Port (optional, defaults to 3456)
PORT=3456
